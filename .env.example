# ─────────────────────────────────────────────────────────────
# KONEPS_sionlab — 환경변수 템플릿
#
# 1. 이 파일을 .env 로 복사:    cp .env.example .env
# 2. 아래 값을 본인 키로 치환 (URL 디코딩된 원본 문자열)
# 3. .env 는 git 에서 제외됨. 절대 커밋하지 말 것
# 4. 권한 제한 권장:             chmod 600 .env
#
# 키 발급 절차:
#   - 공공데이터포털: https://www.data.go.kr/
#   - 조달청_나라장터 입찰공고정보서비스:
#       https://www.data.go.kr/data/15129394/openapi.do
#   - 활용신청 승인까지 1~2시간 소요되는 경우가 있음
#
# URL 인코딩 주의:
#   포털에서 다운로드한 키가 %2B, %2F 등으로 표기되어 있으면
#   "일반 인증키 (Decoding)" 값을 사용할 것. "Encoding" 키 사용 시
#   MCP 서버 내부에서 이중 인코딩되어 401 이 발생한다.
# ─────────────────────────────────────────────────────────────

# Datajang nara-mcp-server + Koomook data-go-mcp 공용
# (입찰공고 / 낙찰 / 계약 조회)
NARA_API_KEY=YOUR_DECODED_SERVICE_KEY_HERE

# Datajang nara-mcp-server 전용 — 사전규격 서비스
# data.go.kr 에서 별도 활용신청이 필요할 수 있음.
# 우선 NARA_API_KEY 와 동일 값으로 시도 → 403 시 별도 신청.
NARA_PRESPEC_API_KEY=YOUR_DECODED_SERVICE_KEY_HERE

# (선택) uv 캐시 링크 모드 — WSL/Docker 등 hardlink 불가 환경에서 필요
# UV_LINK_MODE=copy
