# data.go.kr 공공데이터포털에서 발급받은 인증키 (URL 디코딩된 원본 키 사용)
# 신청: https://www.data.go.kr/data/15129394/openapi.do (조달청_나라장터 입찰공고정보서비스)

# Datajang nara-mcp-server + Koomook data-go-mcp 공용 (입찰공고/낙찰/계약)
NARA_API_KEY=YOUR_DECODED_SERVICE_KEY_HERE

# Datajang nara-mcp-server 전용 (사전규격 서비스, 별도 활용신청 필요할 수 있음)
NARA_PRESPEC_API_KEY=YOUR_DECODED_SERVICE_KEY_HERE
