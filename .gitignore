# 환경변수 / 비밀
.env
.env.local
.env.*.local

# MCP 설정은 키 0개 (.env 에서 로드하는 래퍼 스크립트 경유). 커밋 대상.

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# uv / uvx
.uv-cache/
.venv*/

# Node
node_modules/
npm-debug.log*

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# 로그 / 임시 / DB
*.log
tmp/
temp/
.cache/
*.db
*.sqlite
*.sqlite3

# MCP 원시 응답 캐시 (대용량, 변동성). 규칙 파일만 유지.
data/raw/*.json

# 빌드 결과
dist/
build/
*.egg-info/

# Claude 로컬 (팀 구조는 커밋, 세션/로컬 상태는 제외)
.claude/settings.local.json
.claude/.session/
