{
  "mcpServers": {
    "nara-jangteo": {
      "command": "uvx",
      "args": ["--python", "3.11", "--from", "nara-mcp-server", "nara-server"],
      "env": {
        "NARA_API_KEY": "YOUR_DECODED_SERVICE_KEY_HERE",
        "NARA_PRESPEC_API_KEY": "YOUR_DECODED_SERVICE_KEY_HERE",
        "UV_LINK_MODE": "copy"
      }
    },
    "data-go-mcp.pps-narajangteo": {
      "command": "uvx",
      "args": ["data-go-mcp.pps-narajangteo@latest"],
      "env": {
        "API_KEY": "YOUR_DECODED_SERVICE_KEY_HERE"
      }
    }
  }
}
